<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Usuarios - Mi Proyecto</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
  <%- include('partials/navbar') %>

  <main class="container mt-4">
    <h1 class="mb-4">Usuarios Registrados</h1>

    <% if (!users || users.length === 0) { %>
      <div class="alert alert-info">No hay usuarios registrados.</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-dark">
            <tr>
              <th>Nombre</th>
              <th>Email</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td><strong><%= user.name %></strong></td>
                <td><span class="badge bg-secondary"><%= user.email %></span></td>
                <td class="text-end">
                  <a href="/users/edit/<%= user.id %>" class="btn btn-sm btn-warning">Editar</a>

                  <form action="/users/delete/<%= user.id %>" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('¿Seguro que deseas eliminarlo?')">
                      Eliminar
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <div class="d-flex justify-content-between mt-4">
      <a href="/users/new" class="btn btn-success">Agregar Nuevo Usuario</a>
      <a href="/users?page=1" class="btn btn-outline-primary btn-sm">Ver más (Paginación)</a>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>